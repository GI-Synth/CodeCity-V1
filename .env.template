# Software City — Environment Variables
# Copy to .env and fill in what you need.
# None of these are required for basic operation.

# ──────────────────────────────────────────
# AI PROVIDERS (for agent escalation)
# ──────────────────────────────────────────

# Groq — free tier, ~500 tokens/sec, recommended
# Get key: https://console.groq.com
GROQ_API_KEY=

# Anthropic Claude — best reasoning, ~$0.005/escalation
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Ollama host (if running on a different machine)
# Default: http://localhost:11434
OLLAMA_HOST=

# ──────────────────────────────────────────
# SERVER CONFIG (optional overrides)
# ──────────────────────────────────────────

# API server port (default: 8080)
PORT=

# SQLite database path (default: ./data/city.db)
DB_PATH=

# ──────────────────────────────────────────
# GITHUB (for private repo support)
# ──────────────────────────────────────────
# Enter in the UI — never put your token in this file.
# GitHub PAT is never stored in the database.
