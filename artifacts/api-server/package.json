    "dotenv": "^17.2.3",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "js-interpreter": "^6.0.1",
    "morgan": "^1.10.1",
    "simple-git": "^3.33.0",
    "ws": "^8.19.0"
